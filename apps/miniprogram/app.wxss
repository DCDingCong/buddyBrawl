page {
  min-height: 100%;
  background: #f4efe2;
  color: #2c261d;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 148rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 16% 8%, rgba(91, 124, 71, 0.12), transparent 18%),
    linear-gradient(180deg, #fff8e8 0%, #f1e4c8 100%);
}

.paper-card,
.section {
  margin-bottom: 22rpx;
  padding: 24rpx;
  border: 2rpx solid #d5c5a3;
  border-radius: 18rpx;
  background: rgba(255, 250, 235, 0.9);
  box-shadow: 0 8rpx 0 rgba(90, 68, 35, 0.08);
  box-sizing: border-box;
}

.title {
  color: #2c261d;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.2;
}

.subtitle {
  margin-top: 8rpx;
  color: #6f624e;
  font-size: 24rpx;
  line-height: 1.45;
}

.muted {
  color: #8b7c62;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.primary,
.secondary,
.ghost {
  min-height: 72rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 72rpx;
}

.primary {
  background: linear-gradient(180deg, #5f8e3f, #37652f);
  color: #fffdf5;
  box-shadow: 0 7rpx 0 #244c26;
}

.secondary {
  border: 2rpx solid #d3c09a;
  background: #fff9e9;
  color: #3f3527;
}

.ghost {
  background: transparent;
  color: #315f2e;
}

.icon-button {
  width: 72rpx;
  height: 72rpx;
  padding: 0;
  border-radius: 18rpx;
  font-size: 36rpx;
  line-height: 72rpx;
}

.error {
  margin-bottom: 20rpx;
  padding: 16rpx 20rpx;
  border: 2rpx solid #d66b56;
  border-radius: 12rpx;
  background: #fff0e8;
  color: #a33a28;
  font-size: 24rpx;
}

.brush-label {
  display: inline-flex;
  align-items: center;
  min-height: 58rpx;
  padding: 0 24rpx;
  background: #f1e7cd;
  color: #262015;
  font-size: 34rpx;
  font-weight: 800;
}

.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #e9d6a9;
  color: #5b421c;
  font-size: 22rpx;
  font-weight: 700;
}

.accent {
  color: #d54a2f;
  font-weight: 800;
}
