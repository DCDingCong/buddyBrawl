page {
  min-height: 100%;
  background: #f3f4f6;
  color: #111827;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.section {
  margin-bottom: 24rpx;
  padding: 24rpx;
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.25;
}

.subtitle {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 10rpx 0;
}

.label {
  color: #6b7280;
  font-size: 24rpx;
}

.value {
  color: #111827;
  font-size: 26rpx;
  font-weight: 600;
  text-align: right;
}

.button-row {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

button {
  min-height: 72rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.primary {
  background: #111827;
  color: #ffffff;
}

.secondary {
  background: #e5e7eb;
  color: #111827;
}

.input {
  height: 72rpx;
  margin-top: 16rpx;
  padding: 0 20rpx;
  border: 1rpx solid #d1d5db;
  border-radius: 8rpx;
  background: #ffffff;
  font-size: 26rpx;
}

.error {
  margin-bottom: 20rpx;
  padding: 16rpx;
  border: 1rpx solid #fecaca;
  border-radius: 8rpx;
  background: #fef2f2;
  color: #b91c1c;
  font-size: 24rpx;
}

.list-item {
  padding: 18rpx 0;
  border-top: 1rpx solid #e5e7eb;
}

.list-item:first-child {
  border-top: 0;
}

.mono {
  font-family: ui-monospace, SFMono-Regular, Consolas, monospace;
  font-size: 22rpx;
  white-space: pre-wrap;
  word-break: break-all;
}
