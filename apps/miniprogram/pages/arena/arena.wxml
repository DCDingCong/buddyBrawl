<view class="page">
  <view wx:if="{{error}}" class="error">{{error}}</view>

  <view class="section">
    <view class="title">Arena</view>
    <view class="subtitle">Async battles against real players</view>
    <button class="secondary" loading="{{loading}}" bindtap="refresh">Refresh</button>
  </view>

  <view class="section">
    <view class="title">Opponents</view>
    <view wx:if="{{!hasOpponents}}" class="subtitle">No opponents available</view>
    <view class="list-item" wx:for="{{opponents}}" wx:key="playerId">
      <view class="row">
        <view>
          <view class="value">{{item.nickname}}</view>
          <view class="label">{{item.petName}} Lv.{{item.level}}</view>
        </view>
        <view class="value">{{item.arenaScore}}</view>
      </view>
      <button class="primary" data-id="{{item.playerId}}" loading="{{loading}}" bindtap="challenge">Challenge</button>
    </view>
  </view>

  <view class="section" wx:if="{{result}}">
    <view class="title">Last Result</view>
    <view class="row">
      <view class="label">Winner</view>
      <view class="value">{{result.winner}}</view>
    </view>
    <view class="row">
      <view class="label">Battle ID</view>
      <view class="value mono">{{result.battleId}}</view>
    </view>
  </view>

  <view class="section">
    <view class="title">Recent Battles</view>
    <view wx:if="{{!hasBattles}}" class="subtitle">No battle records</view>
    <view class="list-item" wx:for="{{battles}}" wx:key="battleId" data-id="{{item.battleId}}" bindtap="openBattle">
      <view class="row">
        <view>
          <view class="value">{{item.scene}} / {{item.winner}}</view>
          <view class="label">{{item.createdAt}}</view>
        </view>
        <view class="value">Open</view>
      </view>
    </view>
  </view>
</view>
