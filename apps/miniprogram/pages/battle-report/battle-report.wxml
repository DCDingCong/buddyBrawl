<view class="page">
  <view wx:if="{{error}}" class="error">{{error}}</view>

  <view class="hero">
    <view class="title">战报详情</view>
    <view class="subtitle">回看这场乱斗的关键回合。</view>
  </view>

  <view class="section" wx:if="{{report}}">
    <view class="title">{{resultText}}</view>
    <view class="row">
      <view class="label">我方</view>
      <view class="value">{{report.attacker.petName}} Lv.{{report.attacker.level}}</view>
    </view>
    <view class="row">
      <view class="label">对手</view>
      <view class="value">{{report.defender.petName}} Lv.{{report.defender.level}}</view>
    </view>
  </view>

  <view class="section" wx:if="{{report}}">
    <view class="title">回合记录</view>
    <view class="list-item" wx:for="{{roundTexts}}" wx:key="*this">
      <view class="subtitle">{{item}}</view>
    </view>
  </view>
</view>
