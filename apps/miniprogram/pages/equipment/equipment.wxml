<view class="page weapon-page">
  <view wx:if="{{error}}" class="error">{{error}}</view>

  <view class="brush-label">我的武器</view>

  <view class="weapon-list">
    <view
      class="weapon-row {{selectedId === item.id ? 'active' : ''}}"
      wx:for="{{weapons}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="selectWeapon"
    >
      <view class="weapon-icon">{{item.icon}}</view>
      <view class="weapon-main">
        <view class="weapon-name">{{item.name}} <text>Lv.{{item.level}}</text></view>
        <view class="level-bars">
          <view
            wx:for="{{[1,2,3,4,5,6]}}"
            wx:for-item="bar"
            wx:key="*this"
            class="level-bar {{bar <= item.progress ? 'filled' : ''}}"
          ></view>
        </view>
      </view>
      <button
        class="icon-button {{item.canUpgrade ? 'primary' : 'secondary'}}"
        data-id="{{item.id}}"
        bindtap="upgrade"
        loading="{{loading}}"
      >+</button>
    </view>
  </view>

  <view class="weapon-detail" wx:if="{{selectedWeapon}}">
    <view class="detail-head">
      <view class="detail-icon">{{selectedWeapon.icon}}</view>
      <view class="detail-title">{{selectedWeapon.name}} Lv.{{selectedWeapon.level}}</view>
      <view class="collapse">⌃</view>
    </view>
    <view class="detail-body">
      <view class="preview">
        <view class="subtitle">下次战报可能出现</view>
        <view class="move-card">
          <text class="move-panda">🐼</text>
          <text>{{selectedWeapon.nextText}}</text>
        </view>
      </view>
      <view class="condition">
        <view class="subtitle">成长条件</view>
        <view class="condition-text">{{selectedWeapon.conditionText}}</view>
        <view class="progress-line">
          <view class="progress-fill" style="width: {{selectedWeapon.progressPercent}}%;"></view>
        </view>
        <view class="muted">{{selectedWeapon.progress}}/{{selectedWeapon.target}}</view>
      </view>
      <button class="primary upgrade" data-id="{{selectedWeapon.id}}" bindtap="upgrade">+ 升级</button>
    </view>
  </view>
</view>
