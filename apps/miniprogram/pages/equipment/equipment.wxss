.weapon-page {
  padding-top: 40rpx;
}

.weapon-list {
  margin-top: 28rpx;
}

.weapon-row {
  display: grid;
  grid-template-columns: 106rpx 1fr 72rpx;
  align-items: center;
  gap: 18rpx;
  min-height: 126rpx;
  margin-bottom: 14rpx;
  padding: 14rpx;
  border: 2rpx solid #d8c59d;
  border-radius: 16rpx;
  background: rgba(255, 250, 235, 0.9);
}

.weapon-row.active {
  border-color: #d7a23c;
  box-shadow: inset 8rpx 0 0 #e5bd5d;
}

.weapon-icon {
  width: 92rpx;
  height: 92rpx;
  border-radius: 16rpx;
  background: #edd8a8;
  font-size: 58rpx;
  line-height: 92rpx;
  text-align: center;
}

.weapon-name {
  color: #2f281d;
  font-size: 30rpx;
  font-weight: 900;
}

.level-bars {
  display: flex;
  gap: 8rpx;
  margin-top: 14rpx;
}

.level-bar {
  width: 32rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: #d8ceb8;
}

.level-bar.filled {
  background: #5f8e3f;
}

.weapon-detail {
  margin-top: 24rpx;
  border: 3rpx solid #8a744e;
  border-radius: 18rpx;
  background: #f8edcf;
  overflow: hidden;
}

.detail-head {
  display: grid;
  grid-template-columns: 92rpx 1fr 54rpx;
  align-items: center;
  min-height: 104rpx;
  padding: 12rpx 22rpx;
  background: linear-gradient(90deg, #527a3b, #6f8b54 70%, transparent);
  color: #fff7df;
}

.detail-icon {
  font-size: 64rpx;
}

.detail-title {
  font-size: 40rpx;
  font-weight: 900;
}

.collapse {
  color: #5b4b32;
  font-size: 34rpx;
  text-align: right;
}

.detail-body {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 24rpx;
}

.move-card {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-height: 96rpx;
  margin-top: 12rpx;
  padding: 12rpx;
  border: 2rpx dashed #d2bd94;
  border-radius: 12rpx;
  background: #fff8e8;
  color: #3a3022;
  font-size: 28rpx;
  font-weight: 800;
}

.move-panda {
  font-size: 54rpx;
}

.condition-text {
  margin-top: 12rpx;
  color: #3b3123;
  font-size: 26rpx;
  font-weight: 800;
}

.progress-line {
  height: 18rpx;
  margin: 16rpx 0 8rpx;
  border-radius: 999rpx;
  background: #d2c6ac;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: #5f8e3f;
}

.upgrade {
  grid-column: 1 / -1;
  width: 100%;
}
