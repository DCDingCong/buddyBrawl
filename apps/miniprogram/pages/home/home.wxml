<view class="page home-page">
  <view wx:if="{{error}}" class="error">{{error}}</view>

  <view wx:if="{{!loggedIn}}" class="login-card paper-card">
    <view class="login-panda">🐼</view>
    <view class="title">熊猫乱斗</view>
    <view class="subtitle">带上你的熊猫进竹林，看刚刚发生的热闹，再打一场。</view>
    <button class="primary start" open-type="getPhoneNumber" bindgetphonenumber="startGame" loading="{{loading}}">
      开始乱斗
    </button>
  </view>

  <block wx:if="{{loggedIn}}">
    <view class="profile-card paper-card">
      <view class="panda-avatar">🐼</view>
      <view class="profile-main">
        <view class="title">{{petName}}</view>
        <view class="level">Lv.{{petLevel}}</view>
        <view class="subtitle">{{playerName}}</view>
      </view>
      <view class="edit-dot">✎</view>
    </view>

    <view class="event-board paper-card">
      <view class="title center">胖达刚刚又惹事了</view>
      <view class="event-row" wx:for="{{events}}" wx:key="title">
        <view class="event-icon">{{item.icon}}</view>
        <view class="event-copy">
          <view class="event-title">{{item.title}}</view>
          <view class="subtitle">{{item.text}}</view>
        </view>
        <view class="event-time">{{item.time}}</view>
      </view>
    </view>

    <view class="timer-card paper-card row">
      <view class="timer-icon">⏱</view>
      <view class="timer-copy">
        <view class="event-title">自动记录中</view>
        <view class="subtitle">{{nextRecordText}}</view>
      </view>
      <button class="primary collect" loading="{{loading}}" bindtap="collectRecord">收取</button>
    </view>

    <button class="primary brawl-button" bindtap="goBattle">
      <text class="button-panda">🐼</text>
      再打一场
    </button>

    <view class="quick-actions">
      <button class="secondary" bindtap="goTasks">📋 今日任务</button>
      <button class="secondary" bindtap="showReport">🧾 看最新战报</button>
    </view>
  </block>

  <newspaper-report
    visible="{{reportVisible}}"
    title="胖达小报"
    bind:close="hideReport"
    bind:revenge="goRevenge"
    bind:primary="goBattle"
  />
</view>
