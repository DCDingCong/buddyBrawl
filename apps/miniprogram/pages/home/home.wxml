<view class="page">
  <view wx:if="{{error}}" class="error">{{error}}</view>

  <view class="section">
    <view class="title">Buddy Brawl</view>
    <view class="subtitle">Local API debug entry</view>
    <input class="input" value="{{apiBaseUrl}}" bindinput="onApiBaseUrlInput" />
    <view class="button-row">
      <button class="secondary" bindtap="saveApiBaseUrl">Save API</button>
      <button class="primary" loading="{{loading}}" bindtap="login">Dev Login</button>
    </view>
    <view class="subtitle mono">Token: {{tokenText}}</view>
  </view>

  <view class="section" wx:if="{{home}}">
    <view class="row">
      <view class="label">Player</view>
      <view class="value">{{home.player.nickname}}</view>
    </view>
    <view class="row">
      <view class="label">Pet</view>
      <view class="value">{{home.currentPet.name}} Lv.{{home.currentPet.level}}</view>
    </view>
    <view class="row">
      <view class="label">Arena Score</view>
      <view class="value">{{home.arena.score}}</view>
    </view>
    <view class="row">
      <view class="label">Stage</view>
      <view class="value">{{home.adventure.currentStageName}}</view>
    </view>
    <view class="row">
      <view class="label">Tasks Ready</view>
      <view class="value">{{home.tasks.unclaimedCount}}</view>
    </view>
    <view class="button-row">
      <button class="secondary" bindtap="goAdventure">Adventure</button>
      <button class="secondary" bindtap="goEquipment">Gear</button>
      <button class="secondary" bindtap="goArena">Arena</button>
    </view>
  </view>

  <view class="section" wx:if="{{home}}">
    <view class="title">Current Pet</view>
    <view class="row"><view class="label">HP</view><view class="value">{{home.currentPet.stats.hp}}</view></view>
    <view class="row"><view class="label">Attack</view><view class="value">{{home.currentPet.stats.attack}}</view></view>
    <view class="row"><view class="label">Defense</view><view class="value">{{home.currentPet.stats.defense}}</view></view>
    <view class="row"><view class="label">Speed</view><view class="value">{{home.currentPet.stats.speed}}</view></view>
  </view>
</view>
