<view class="page">
  <view class="paper-card setup-card">
    <view class="setup-panda">🐼</view>
    <view class="title">创建你的熊猫</view>
    <view class="subtitle">系统已经为你准备好初始体型、花纹和第一件武器。</view>
  </view>

  <view class="section">
    <view class="row">
      <view class="subtitle">默认昵称</view>
      <view class="title small">{{pandaName}}</view>
    </view>
    <view class="subtitle">首版本会自动创建完整角色，后续再开放更多局部装饰选择。</view>
    <button class="primary" bindtap="enterGame">进入竹林</button>
  </view>
</view>
